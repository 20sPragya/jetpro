# Copy this file to .env and fill in your values.
# The server works without any of these (DEV mode — emails are logged, not sent).

# ---------- server ----------
PORT=3000

# ---------- SMTP (leave blank to use DEV / log-only mode) ----------
# Gmail example (use an App Password, not your account password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#
# Resend example:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ---------- email addresses ----------
# Who receives new campaign enquiries (your inbox).
MAIL_TO=info@jetpromedia.com

# The "From" address shown on outgoing emails.
# Use an address on a domain you control and have verified (SPF/DKIM).
MAIL_FROM=JetPro Media <no-reply@jetpromedia.com>
